@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Intern Dashboard</title>
    <link rel="stylesheet" href="@Url.Content("~/giaodien/page 3.css")">
</head>
<body>

    <header class="topbar">
        <div class="topbar-brand">INTERN PORTAL</div>
        <ul class="topbar-menu">
            <li class="active">
                <a href="#"><i>📋</i> <span>My Activities</span></a>
            </li>
            <li class="logout-btn">
                <a href="/Home/Logout"><i>🚪</i> <span>Log Out</span></a>
            </li>
        </ul>
    </header>

    <main class="main-content">
        <div class="container">

            <div class="profile-global">
                <div class="profile-info">
                    <div>
                        <h2>Milan Borjan (Intern)</h2>
                        <p><strong>Bộ Phận Đang Làm:</strong> Dev Department</p>
                    </div>
                </div>

                <div>
                    <span id="txt-status" class="status-badge status-learning">Trạng thái: Đang Hướng Dẫn</span>
                    <button onclick="toggleCompleteStatusTest()" style="margin-left:10px; font-size:11px; padding:4px; cursor:pointer;">(Test: Toggle Complete)</button>
                </div>
            </div>

            <div class="split-layout">

                <div class="mentor-profile-card">
                    <p style="font-size:12px; font-weight:bold; color:#64748b; margin-bottom:10px; text-transform:uppercase;">Người hướng dẫn của bạn</p>

                    <h4>Jesse Marsch</h4>
                    <div class="role-text">Senior Developer / Mentor</div>

                    <div class="info-list">
                        <p><strong>Email:</strong> jesse.m@company.com</p>
                        <p><strong>Phone:</strong> 0933.888.999</p>
                        <p><strong>Vị trí ngồi:</strong> Phòng Kỹ Thuật - Khu B</p>
                    </div>

                    <button id="btn-survey-id" class="btn-survey" disabled onclick="openSurveyModal()">
                        📝 Tham gia khảo sát
                    </button>
                    <small id="survey-hint" style="color:#ef4444; font-size:11px; display:block; margin-top:8px;">
                        *Chỉ mở khi Mentor xác nhận Hoàn Thành hướng dẫn.
                    </small>
                </div>

                <div class="activity-container">
                    <h3>Nhật ký hoạt động của tôi</h3>

                    <div id="intern-log-container" class="activity-container" style="gap: 20px; width: 100%;">
                        <p style="text-align:center; color:#64748b; padding: 20px;">Đang tải danh sách nhật ký hoạt động từ hệ thống C#...</p>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <div id="activity-modal" class="modal-overlay">
        <div class="modal-box">
            <div class="modal-header">
                <h4>🔍 Chi tiết hoạt động & Phản hồi</h4>
                <p style="font-size: 13px; color: #64748b; margin-top: 4px;">Thông tin do Mentor thiết lập (Chỉ xem). Bạn có thể để lại phản hồi ở mục dưới cùng.</p>
            </div>

            <form id="activity-form" onsubmit="handleInternCommentSubmit(event)">
                <input type="hidden" id="form-activity-id" />

                <div class="form-group">
                    <label>Tên hoạt động</label>
                    <input type="text" id="form-name" disabled style="background:#f1f5f9;">
                </div>

                <div class="form-group">
                    <label>Địa điểm</label>
                    <input type="text" id="form-location" disabled style="background:#f1f5f9;">
                </div>

                <div class="form-group-row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div class="form-group">
                        <label>Ngày giờ thực hiện</label>
                        <input type="text" id="form-datetime" disabled style="background:#f1f5f9;">
                    </div>
                    <div class="form-group">
                        <label>Thời lượng</label>
                        <input type="text" id="form-duration" disabled style="background:#f1f5f9;">
                    </div>
                </div>

                <div class="form-group">
                    <label>Miêu tả chi tiết công việc từ Mentor</label>
                    <textarea id="form-desc" disabled style="background:#f1f5f9; min-height: 60px;"></textarea>
                </div>

                <div class="form-group" style="border-top: 2px dashed #0078d4; padding-top: 15px; margin-top: 20px;">
                    <label style="color: var(--primary-color); font-size: 15px;">✍ Ý kiến / Phản hồi của Intern (Bạn):</label>
                    <textarea id="form-comment" placeholder="Nhập câu hỏi, báo cáo tiến độ hoặc ghi chú của bạn tại đây..." required style="border: 1px solid var(--primary-color); font-family: inherit; resize: vertical;"></textarea>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-form cancel" onclick="closeModal('activity-modal')">Cancel</button>
                    <button type="submit" class="btn-form submit">Save Comment</button>
                </div>
            </form>
        </div>
    </div>

    <div id="survey-modal" class="modal-overlay">
        <div class="modal-box">
            <div class="modal-header">
                <h4>📝 Khảo sát kết thúc kỳ Thực tập</h4>
                <p style="font-size:13px; color:#64748b; margin-top:4px;">Ý kiến của bạn sẽ giúp cải thiện chất lượng quản lý.</p>
            </div>

            <form id="survey-form" onsubmit="handleSurveySubmit(event)">
                <div class="form-group">
                    <label>Bạn đánh giá điểm số cho Mentor của mình thế nào?</label>
                    <select id="survey-score" required>
                        <option value="5">⭐⭐⭐⭐⭐ 5/5 - Rất xuất sắc và tận tình</option>
                        <option value="4">⭐⭐⭐⭐ 4/5 - Tốt, hỗ trợ nhiệt tình</option>
                        <option value="3">⭐⭐⭐ 3/5 - Bình thường, đủ yêu cầu</option>
                        <option value="2">⭐⭐ 2/5 - Ít tương tác, hỗ trợ chậm</option>
                        <option value="1">⭐ 1/5 - Không hỗ trợ công việc</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Ý kiến đóng góp / Phản hồi chi tiết dành cho Người hướng dẫn:</label>
                    <textarea id="survey-feedback" required placeholder="Nhập cảm nghĩ, đề xuất hoặc khó khăn bạn gặp phải trong kỳ thực tập..."></textarea>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-form cancel" onclick="closeModal('survey-modal')">Cancel</button>
                    <button type="submit" class="btn-form submit" style="background:var(--purple-color)">Submit Survey</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const pairKey = "pair-01";
        let isMentorCompleted = false;

        document.addEventListener("DOMContentLoaded", function () {
            loadInternActivities();
        });

        // 1. Hàm GET: Tự động kéo các hoạt động từ C# Web API về và vẽ khối Card chuẩn giao diện gốc của bạn
        function loadInternActivities() {
            fetch(`/api/activities/getbykey?pairKey=${pairKey}`, {
                method: 'GET',
                headers: {
                    'Accept': 'application/json'
                }
            })
                .then(response => {
                    if (!response.ok) throw new Error("Không thể kết nối lấy dữ liệu từ API!");
                    return response.json();
                })
                .then(logs => {
                    const container = document.getElementById('intern-log-container');
                    container.innerHTML = "";

                    if (logs.length === 0) {
                        container.innerHTML = `<div style="text-align:center; color:#64748b; padding: 25px; background:#f8fafc; border-radius:12px; border: 1px dashed #cbd5e1;">Chưa có hoạt động nào được ghi nhận từ Người hướng dẫn.</div>`;
                        return;
                    }

                    logs.forEach((log, index) => {
                        const card = document.createElement('div');
                        card.className = "activity-card";

                        let displayDate = log.Date ? log.Date.replace('T', ' ') : '';

                        card.innerHTML = `
                            <div class="activity-header">
                                <span class="activity-title">Hoạt động ${index + 1}: ${log.Title}</span>
                                <span class="status-badge" style="background:#e2e8f0; color:#334155; font-size:12px; padding:3px 10px;">Hoạt động ${index + 1}</span>
                            </div>
                            <div class="activity-meta">
                                <div>📍 <strong>Địa điểm:</strong> ${log.Location}</div>
                                <div>⏱ <strong>Thời gian làm:</strong> ${log.Duration}</div>
                                <div>📅 <strong>Ngày giờ:</strong> ${displayDate}</div>
                            </div>
                            <p style="font-size:14px; color:#475569; margin-bottom:12px; line-height:1.5; padding: 0 5px;">
                                ${log.Description}
                            </p>
                            <div class="activity-comment">
                                <strong>Phản hồi từ Mentor:</strong> "${log.InternComment || "Bạn chưa để lại phản hồi nào cho hoạt động này."}"
                            </div>
                            <div class="card-actions">
                                <button class="btn-card view" onclick="openInternCommentModal(${log.Id}, '${log.Title.replace(/'/g, "\\'")}', '${log.Location.replace(/'/g, "\\'")}', '${log.Date}', '${log.Duration.replace(/'/g, "\\'")}', '${log.Description.replace(/'/g, "\\'")}', '${(log.InternComment || "").replace(/'/g, "\\'")}')">
                                    🔍 View & Comment
                                </button>
                            </div>
                        `;
                        container.appendChild(card);
                    });
                })
                .catch(error => {
                    console.error("Lỗi nạp danh sách card:", error);
                    document.getElementById('intern-log-container').innerHTML = `<div style="color:#ef4444; text-align:center; padding:15px;">❌ Không thể kết nối đến Backend C#!</div>`;
                });
        }

        // Mở Modal xem chi tiết và điền dữ liệu động
        function openInternCommentModal(id, title, location, date, duration, desc, comment) {
            const modal = document.getElementById('activity-modal');

            document.getElementById('form-activity-id').value = id;
            document.getElementById('form-name').value = title;
            document.getElementById('form-location').value = location;
            document.getElementById('form-datetime').value = date;
            document.getElementById('form-duration').value = duration;
            document.getElementById('form-desc').value = desc;
            document.getElementById('form-comment').value = comment;

            modal.classList.add('open');
        }

        function openSurveyModal() {
            if (!isMentorCompleted) return;
            document.getElementById('survey-modal').classList.add('open');
        }

        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove('open');
        }

        // 2. Hàm POST: Gửi nội dung phản hồi của Intern gõ lên một API cập nhật bình luận riêng biệt (Hoặc dùng tạm hàm update có sẵn)
        function handleInternCommentSubmit(event) {
            event.preventDefault();
            const id = document.getElementById('form-activity-id').value;

            const commentData = {
                Title: document.getElementById('form-name').value,
                Location: document.getElementById('form-location').value,
                Date: document.getElementById('form-datetime').value,
                Duration: document.getElementById('form-duration').value,
                Description: document.getElementById('form-desc').value,
                InternComment: document.getElementById('form-comment').value // Gửi nội dung bình luận mới lên
            };

            // Tận dụng đầu cuối update ngầm POST trên Server C# để cập nhật chuỗi comment
            fetch(`/api/activities/update/${id}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(commentData)
            })
                .then(response => {
                    if (!response.ok) throw new Error("Server từ chối cập nhật bình luận!");
                    return response.json();
                })
                .then(result => {
                    if (result.success) {
                        alert("Bình luận phản hồi của Intern đã được lưu thành công!");
                        closeModal('activity-modal');
                        loadInternActivities(); // Nạp lại danh sách card để thấy phản hồi mới ngay lập tức
                    }
                })
                .catch(error => {
                    console.error("Lỗi gửi comment:", error);
                    alert("Không thể lưu phản hồi biểu mẫu!");
                });
        }

        function handleSurveySubmit(event) {
            event.preventDefault();
            alert("Cảm ơn bạn! Phiếu khảo sát đánh giá Mentor đã được gửi lên hệ thống thành công.");
            closeModal('survey-modal');
            document.getElementById('survey-form').reset();
        }

        function toggleCompleteStatusTest() {
            isMentorCompleted = !isMentorCompleted;

            const btnSurvey = document.getElementById('btn-survey-id');
            const hintText = document.getElementById('survey-hint');
            const badgeStatus = document.getElementById('txt-status');

            if (isMentorCompleted) {
                badgeStatus.innerText = "Trạng thái: Đã Hoàn Thành (Complete)";
                badgeStatus.className = "status-badge status-complete";
                btnSurvey.disabled = false;
                hintText.style.color = "var(--success-color)";
                hintText.innerText = "✔ Bạn đủ điều kiện tham gia khảo sát.";
            } else {
                badgeStatus.innerText = "Trạng thái: Đang Hướng Dẫn";
                badgeStatus.className = "status-badge status-learning";
                btnSurvey.disabled = true;
                hintText.style.color = "#ef4444";
                hintText.innerText = "*Chỉ mở khi Mentor xác nhận Hoàn Thành hướng dẫn.";
            }
        }
    </script>
</body>
</html>