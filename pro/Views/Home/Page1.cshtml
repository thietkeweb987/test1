
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Management System</title>
    <link rel="stylesheet"  href="~/GiaoDien/page 1.css">
</head>
<body>

    <nav class="sidebar">
        <div class="sidebar-brand">AD PANEL</div>
        <ul class="sidebar-menu">
            <li class="active" onclick="switchTab('dashboard-tab', this)">
                <a><i>📊</i> <span>Dashboard</span></a>
            </li>
            <li onclick="switchTab('add-user-tab', this)">
                <a><i>📥</i> <span>Add User</span></a>
            </li>
            <li onclick="switchTab('create-pair-tab', this)">
                <a><i>👥</i> <span>Create Pair</span></a>
            </li>
            <li onclick="switchTab('survey-report-tab', this)">
                <a><i>📝</i> <span>Survey Report</span></a>
            </li>
            <li class="logout-btn">
                <a href="#logout" onclick="alert('Đăng xuất hệ thống thành công')"><i>🚪</i> <span>Log Out</span></a>
            </li>
        </ul>
    </nav>

    <main class="main-content">
        <div class="container">

            <div class="profile">
                <div>
                    <h2>Hello Jesse Marsch</h2>
                    <p><strong>Role:</strong> Administrator</p>
                </div>
            </div>

            <div id="dashboard-tab" class="tab-panel active">
                <h3>System Overview</h3>
                <p style="color: #64748b; margin-bottom: 15px;">Click vào từng thẻ bên dưới để xem danh sách chi tiết và kiểm tra tương tác.</p>

                <div class="stats-grid">
                    <div class="card" onclick="showDashboardDetail('nhanvien', this)">
                        <h4>Tổng Nhân Viên</h4>
                        <p>5</p>
                    </div>
                    <div class="card" onclick="showDashboardDetail('intern', this)">
                        <h4>Tổng Intern</h4>
                        <p>6</p>
                    </div>
                    <div class="card" onclick="showDashboardDetail('good-pairs', this)">
                        <h4>Cặp Đang Tốt</h4>
                        <p>2</p>
                    </div>
                    <div class="card" onclick="showDashboardDetail('need-work-pairs', this)">
                        <h4>Cần Hỗ Trợ</h4>
                        <p>1</p>
                    </div>
                    <div class="card urgent-card" onclick="showDashboardDetail('urgent-alerts', this)">
                        <h4 style="color: var(--urgent-color); font-weight: bold;">🚨 Urgent Alert</h4>
                        <p style="color: var(--urgent-color);">2</p>
                    </div>
                </div>

                <div id="dashboard-detail-container" class="dashboard-detail-section" style="display: none;">
                    <h3 id="detail-title">Danh sách chi tiết</h3>
                    <div id="detail-table-wrapper"></div>
                </div>
            </div>

            <div id="add-user-tab" class="tab-panel">
                <h3>Add User via Excel</h3>
                <p style="color: #64748b;">Chọn phương thức nhập dữ liệu Excel tương ứng cho từng nhóm đối tượng.</p>

                <div class="upload-container">
                    <div class="upload-section">
                        <h4>Upload File Nhân Viên</h4>
                        <p style="margin-top: 8px; font-size: 14px; color: #64748b;">Hệ thống sẽ tự động cập nhật thông tin tài khoản nhân viên mới.</p>
                        <div class="upload-btn-wrapper">
                            <button class="btn-upload">📁 Select Employee Excel</button>
                            <input type="file" accept=".xlsx, .xls" />
                        </div>
                    </div>

                    <div class="upload-section">
                        <h4>Upload File Intern</h4>
                        <p style="margin-top: 8px; font-size: 14px; color: #64748b;">Dữ liệu Intern sau khi tải lên sẽ nằm trong hàng đợi tạo cặp gán ghép.</p>
                        <div class="upload-btn-wrapper">
                            <button class="btn-upload">📁 Select Intern Excel</button>
                            <input type="file" accept=".xlsx, .xls" />
                        </div>
                    </div>
                </div>
            </div>

            <div id="create-pair-tab" class="tab-panel">
                <h3>Create Mentor - Intern Pairs</h3>
                <p style="color: #64748b; margin-bottom: 20px;">Gán ghép cặp quản lý. Xem số lượng Intern hiện tại bên cạnh tên Nhân viên để tránh quá tải.</p>

                <table>
                    <thead>
                        <tr>
                            <th>STT</th>
                            <th>Tên Intern</th>
                            <th>Tuổi</th>
                            <th>Giới tính</th>
                            <th>Bộ Phận</th>
                            <th>Chọn Nhân Viên Hướng Dẫn (Mentor)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>1</td>
                            <td><strong>Milan Borjan (Intern)</strong></td>
                            <td>18</td>
                            <td>Female</td>
                            <td>Dev</td>
                            <td>
                                <select>
                                    <option value="1">Steven Vitoria (Đang có: 0)</option>
                                    <option value="2" selected>Milan Borjan (Đang có: 2)</option>
                                    <option value="3">James Pantemis (Đang có: 6 - QUÁ TẢI)</option>
                                </select>
                            </td>
                        </tr>
                        <tr>
                            <td>2</td>
                            <td><strong>James Pantemis (Intern)</strong></td>
                            <td>19</td>
                            <td>Male</td>
                            <td>QA</td>
                            <td>
                                <select>
                                    <option value="1">Steven Vitoria (Đang có: 0)</option>
                                    <option value="2">Milan Borjan (Đang có: 2)</option>
                                    <option value="3" selected>James Pantemis (Đang có: 6 - QUÁ TẢI)</option>
                                </select>
                            </td>
                        </tr>
                    </tbody>
                </table>
                <button class="save-btn">Save Pairs</button>
            </div>

            <div id="survey-report-tab" class="tab-panel">
                <h3>Survey Report từ Intern</h3>
                <table>
                    <thead>
                        <tr>
                            <th>STT</th>
                            <th>Tên Intern</th>
                            <th>Mentor Đánh Giá</th>
                            <th>Điểm</th>
                            <th>Ý Kiến Phản Hồi</th>
                            <th>Ngày gửi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td>1</td><td>Milan Borjan</td><td>Milan Borjan</td><td style="color:green; font-weight:600;">5/5</td><td>"Mentor chỉ dẫn rất tận tình."</td><td>15/05/2026</td></tr>
                    </tbody>
                </table>
            </div>

        </div>
    </main>

    <div id="admin-view-activity-modal" class="modal-overlay">
        <div class="modal-box" style="max-width: 850px; width: 90%;">
            <div class="modal-header" style="display: flex; justify-content: space-between; align-items: center;">
                <h4 id="modal-main-title">📜 Nhật Ký Hoạt Động Của Cặp</h4>
                <button onclick="closeAdminModal()" style="background:none; border:none; font-size:20px; cursor:pointer; color:#64748b;">✕</button>
            </div>

            <div id="modal-screen-list">
                <p style="color: #64748b; margin-bottom: 15px; font-size: 14px;">Dưới đây là toàn bộ các hoạt động được ghi nhận của cặp đôi này.</p>
                <div style="max-height: 350px; overflow-y: auto; border: 1px solid var(--border-color); border-radius: 8px;">
                    <table style="margin-bottom: 0;">
                        <thead style="position: sticky; top: 0; background: var(--primary-color);">
                            <tr>
                                <th>STT</th>
                                <th>Ngày Thực Hiện</th>
                                <th>Tên Hoạt Động</th>
                                <th>Thời Lượng</th>
                                <th>Hành Động</th>
                            </tr>
                        </thead>
                        <tbody id="modal-log-tbody">
                        </tbody>
                    </table>
                </div>
                <div style="display:flex; justify-content: flex-end; margin-top:20px;">
                    <button class="btn-table-action" onclick="closeAdminModal()" style="padding: 8px 20px;">Đóng</button>
                </div>
            </div>

            <div id="modal-screen-detail" style="display: none;">
                <button onclick="backToLogList()" style="background: none; border: none; color: var(--primary-color); cursor: pointer; font-weight: 600; margin-bottom: 15px; display: flex; align-items: center; gap: 5px;">
                    ⬅ Quay lại danh sách tổng hợp
                </button>

                <div class="form-group">
                    <label>Tên hoạt động</label>
                    <input type="text" id="view-detail-name" disabled>
                </div>
                <div class="form-group">
                    <label>Địa điểm tổ chức</label>
                    <input type="text" id="view-detail-location" disabled>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap:15px;">
                    <div class="form-group">
                        <label>Ngày giờ thực hiện</label>
                        <input type="text" id="view-detail-datetime" disabled>
                    </div>
                    <div class="form-group">
                        <label>Thời lượng</label>
                        <input type="text" id="view-detail-duration" disabled>
                    </div>
                </div>
                <div class="form-group">
                    <label>Miêu tả chi tiết công việc (Do Mentor tạo)</label>
                    <textarea id="view-detail-desc" disabled></textarea>
                </div>
                <div class="form-group" style="border-top: 1px dashed #cbd5e1; padding-top: 10px;">
                    <label style="color: var(--primary-color);">💬 Phản hồi / Comment từ phía Intern:</label>
                    <textarea id="view-detail-comment" disabled style="font-style: italic; background-color: #f0fdf4; color: #166534;"></textarea>
                </div>
            </div>

        </div>
    </div>

    <script>
        // Giả lập Database chứa NHIỀU LOG của các cặp đôi để sẵn sàng map với API sau này
        const mockLogsDatabase = {
            "milan-pair": [
                { id: 101, date: "16/05/2026", title: "Nghiên cứu cấu trúc Dự án ASP.NET", duration: "4 tiếng", location: "Phòng họp tầng 2", desc: "Đọc hiểu cấu trúc source code gốc của hệ thống quản lý. Hướng dẫn phân tách tầng dữ liệu và nghiệp vụ API.", comment: "Em đã hiểu cấu trúc thư mục code tốt, tuần tới em sẽ chạy thử kết nối database." },
                { id: 102, date: "12/05/2026", title: "Thiết kế Database SQL Server", duration: "3 tiếng", location: "Bàn làm việc khu Đột Phá", desc: "Cùng Intern ngồi chuẩn hóa thực thể các bảng User, Pair, Logs. Hướng dẫn tạo Khóa chính và Khóa ngoại.", comment: "Phần khóa ngoại hơi rắc rối nhưng nhờ Mentor giải thích bằng hình vẽ nên em đã thông suốt." },
                { id: 103, date: "05/05/2026", title: "Onboarding & Hướng dẫn cài đặt IDE", duration: "2 tiếng", location: "Phòng Tech 1", desc: "Cài đặt Visual Studio 2026, cấu hình Git của công ty và clone dự án thử nghiệm về máy cá nhân.", comment: "Môi trường máy em đã chạy mượt mà, sẵn sàng nhận nhiệm vụ." }
            ],
            "alphonso-pair": [
                { id: 201, date: "10/05/2026", title: "Review Kịch bản Kiểm thử (Test Case)", duration: "5 tiếng", location: "Phòng họp Test Team", desc: "Kiểm tra toàn bộ các file testcase Excel do Intern viết cho module Đăng nhập và Đăng ký.", comment: "Mentor sửa cho em nhiều lỗi bắt bài logic sai của User rất hay." }
            ],
            "liam-pair": [
                { id: 301, date: "12/02/2026", title: "Gặp mặt định hướng tuần đầu tiên", duration: "1.5 tiếng", location: "Căng tin công ty", desc: "Trao đổi tổng quan về định hướng công việc trong 3 tháng tới của Intern.", comment: "Buổi gặp vui vẻ, Mentor rất thân thiện." }
            ]
        };

        function switchTab(tabId, element) {
            const tabs = document.querySelectorAll('.tab-panel');
            tabs.forEach(tab => tab.classList.remove('active'));
            document.getElementById(tabId).classList.add('active');

            const menuItems = document.querySelectorAll('.sidebar-menu li');
            menuItems.forEach(item => item.classList.remove('active'));
            element.classList.add('active');

            if(tabId !== 'dashboard-tab') {
                document.getElementById('dashboard-detail-container').style.display = 'none';
                document.querySelectorAll('.card').forEach(c => c.classList.remove('selected-card'));
            }
        }

        function showDashboardDetail(type, cardElement) {
            document.querySelectorAll('.card').forEach(c => c.classList.remove('selected-card'));
            cardElement.classList.add('selected-card');

            const container = document.getElementById('dashboard-detail-container');
            const title = document.getElementById('detail-title');
            const wrapper = document.getElementById('detail-table-wrapper');

            container.style.display = 'block';
            let htmlTable = '';

            if (type === 'nhanvien') {
                title.innerText = "Danh sách chi tiết: Toàn bộ Nhân Viên";
                htmlTable = `
                    <table>
                        <thead>
                            <tr><th>STT</th><th>Họ Tên</th><th>Bộ Phận</th><th>Số Lượt Login Hệ Thống</th></tr>
                        </thead>
                        <tbody>
                            <tr><td>1</td><td>Steven Vitoria</td><td>Dev</td><td>42 lần</td></tr>
                            <tr><td>2</td><td>Milan Borjan</td><td>Dev</td><td>89 lần</td></tr>
                            <tr><td>3</td><td>James Pantemis</td><td>QA</td><td>12 lần</td></tr>
                        </tbody>
                    </table>`;
            }
            else if (type === 'intern') {
                title.innerText = "Danh sách chi tiết: Toàn bộ Intern";
                htmlTable = `
                    <table>
                        <thead>
                            <tr><th>STT</th><th>Họ Tên Intern</th><th>Bộ Phận</th><th>Số Lượt Login Hệ Thống</th></tr>
                        </thead>
                        <tbody>
                            <tr><td>1</td><td>Milan Borjan (Intern)</td><td>Dev</td><td>31 lần</td></tr>
                            <tr><td>2</td><td>James Pantemis (Intern)</td><td>QA</td><td>5 lần</td></tr>
                        </tbody>
                    </table>`;
            }
            else if (type === 'good-pairs') {
                title.innerText = "Danh sách: Các cặp đang hoạt động TỐT (Good)";
                htmlTable = `
                    <table>
                        <thead>
                            <tr><th>STT</th><th>Cặp Mentor ➔ Intern</th><th>Bộ Phận</th><th>Tổng số lượt Login</th><th>Trạng thái</th><th>Kiểm tra hoạt động</th></tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>1</td><td>Milan Borjan ➔ Milan Borjan</td><td>Dev</td><td>120 lần</td>
                                <td><span class="status-badge badge-good">Good</span></td>
                                <td><button class="btn-table-action" onclick="openAdminModal('milan-pair', 'Milan Borjan ➔ Milan Borjan')">🔍 View Logs</button></td>
                            </tr>
                        </tbody>
                    </table>`;
            }
            else if (type === 'need-work-pairs') {
                title.innerText = "Danh sách: Các cặp CẦN HỖ TRỢ (Need Work)";
                htmlTable = `
                    <table>
                        <thead>
                            <tr><th>STT</th><th>Cặp Mentor ➔ Intern</th><th>Bộ Phận</th><th>Tổng số lượt Login</th><th>Trạng thái</th><th>Kiểm tra hoạt động</th></tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>1</td><td>Alphonso Davies ➔ Tajon Buchanan</td><td>Test</td><td>18 lần</td>
                                <td><span class="status-badge badge-need-work">Need Work</span></td>
                                <td><button class="btn-table-action" onclick="openAdminModal('alphonso-pair', 'Alphonso Davies ➔ Tajon Buchanan')">🔍 View Logs</button></td>
                            </tr>
                        </tbody>
                    </table>`;
            }
            else if (type === 'urgent-alerts') {
                title.innerText = "🚨 HỆ THỐNG CẢNH BÁO KHẨN CẤP (URGENT ALERTS)";
                htmlTable = `
                    <table>
                        <thead>
                            <tr><th>STT</th><th>Cặp Mentor ➔ Intern</th><th>Bộ Phận</th><th>Lần tương tác cuối</th><th>Lý do Cảnh báo</th><th>Trạng thái</th><th>Chi tiết form cuối</th></tr>
                        </thead>
                        <tbody>
                            <tr style="background-color: #fffffa;">
                                <td>1</td><td>James Pantemis ➔ Cyle Larin</td><td>QA</td><td>Chưa từng Login</td>
                                <td style="color: var(--urgent-color); font-weight:600;">Quá 3 tuần kể từ lúc tạo tài khoản chưa Login hệ thống</td>
                                <td><span class="status-badge badge-urgent">Urgent Alert</span></td>
                                <td><button class="btn-table-action" style="cursor: not-allowed; opacity: 0.5;" disabled>No Logs</button></td>
                            </tr>
                            <tr style="background-color: #fffffa;">
                                <td>2</td><td>Liam Millar ➔ Kwasi Poku</td><td>Dev</td><td>12/02/2026</td>
                                <td style="color: var(--urgent-color); font-weight:600;">Quá 3 tháng không có bất kỳ ghi nhận hoạt động nào</td>
                                <td><span class="status-badge badge-urgent">Urgent Alert</span></td>
                                <td><button class="btn-table-action" onclick="openAdminModal('liam-pair', 'Liam Millar ➔ Kwasi Poku')">🔍 View Logs</button></td>
                            </tr>
                        </tbody>
                    </table>`;
            }

            wrapper.innerHTML = htmlTable;
        }

        // Hiện Modal - Đổ danh sách gồm NHIỀU LOG vào bảng
        let currentActivePairKey = '';
        function openAdminModal(pairKey, pairName) {
            currentActivePairKey = pairKey;
            document.getElementById('modal-main-title').innerText = `📜 Nhật Ký Hoạt Động: ${pairName}`;

            // Trở về màn hình danh sách trước
            document.getElementById('modal-screen-list').style.display = 'block';
            document.getElementById('modal-screen-detail').style.display = 'none';

            const logs = mockLogsDatabase[pairKey] || [];
            const tbody = document.getElementById('modal-log-tbody');
            tbody.innerHTML = '';

            if(logs.length === 0) {
                tbody.innerHTML = `<tr><td colspan="5" style="text-align:center; color:#94a3b8;">Chưa có log hoạt động nào được ghi nhận.</td></tr>`;
            } else {
                logs.forEach((log, index) => {
                    tbody.innerHTML += `
                        <tr>
                            <td>${index + 1}</td>
                            <td><b>${log.date}</b></td>
                            <td>${log.title}</td>
                            <td>${log.duration}</td>
                            <td><button class="btn-table-action" style="padding:4px 8px; font-size:12px;" onclick="viewSingleLogDetail(${index})">Xem Chi Tiết ➔</button></td>
                        </tr>
                    `;
                });
            }

            document.getElementById('admin-view-activity-modal').classList.add('open');
        }

        // Chuyển sang màn hình 2: Xem chi tiết 1 Log được chọn
        function viewSingleLogDetail(logIndex) {
            const logData = mockLogsDatabase[currentActivePairKey][logIndex];

            // Điền dữ liệu tương ứng vào form read-only
            document.getElementById('view-detail-name').value = logData.title;
            document.getElementById('view-detail-location').value = logData.location;
            document.getElementById('view-detail-datetime').value = logData.date;
            document.getElementById('view-detail-duration').value = logData.duration;
            document.getElementById('view-detail-desc').value = logData.desc;
            document.getElementById('view-detail-comment').value = logData.comment;

            // Chuyển hiệu ứng ẩn hiện màn hình
            document.getElementById('modal-screen-list').style.display = 'none';
            document.getElementById('modal-screen-detail').style.display = 'block';
        }

        // Quay lại màn hình danh sách log
        function backToLogList() {
            document.getElementById('modal-screen-list').style.display = 'block';
            document.getElementById('modal-screen-detail').style.display = 'none';
        }

        function closeAdminModal() {
            document.getElementById('admin-view-activity-modal').classList.remove('open');
        }
    </script>
</body>
</html>