@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Employee / Mentor Dashboard</title>
    <link rel="stylesheet" href="@Url.Content("~/giaodien/page 2.css")">
</head>
<body>

    <header class="topbar">
        <div class="topbar-brand">MENTOR PORTAL</div>
        <ul class="topbar-menu">
            <li class="active" id="menu-list" onclick="navigateToDashboard()">
                <a><i>📋</i> <span>Mentees List</span></a>
            </li>
            <li class="logout-btn">
                <a href="/Home/Logout"><i>🚪</i> <span>Log Out</span></a>
            </li>
        </ul>
    </header>

    <main class="main-content">
        <div class="container">

            <div class="profile-global">
                <div>
                    <h2>Hello Jesse Marsch</h2>
                    <p><strong>Bộ Phận:</strong> Dev (Mentor)</p>
                </div>
            </div>

            <div id="intern-list-view">
                <h3>Danh sách Intern đang hướng dẫn</h3>
                <table>
                    <thead>
                        <tr>
                            <th>STT</th>
                            <th>Name</th>
                            <th>Bộ Phận</th>
                            <th>Ngày Start</th>
                            <th>Ngày còn lại</th>
                            <th>View</th>
                            <th>Complete</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>1</td>
                            <td><strong>Milan Borjan</strong></td>
                            <td>Dev</td>
                            <td>5/12/2026</td>
                            <td>365</td>
                            <td><button class="btn-view" onclick="openInternDetail('Milan Borjan', 'milan.b@company.com', '0901.234.567')">View</button></td>
                            <td><span class="badge">Complete</span></td>
                        </tr>
                        <tr>
                            <td>2</td>
                            <td><strong>Alphonso Davies</strong></td>
                            <td>Dev</td>
                            <td>10/01/2026</td>
                            <td>240</td>
                            <td><button class="btn-view" onclick="openInternDetail('Alphonso Davies', 'davies.a@company.com', '0911.999.888')">View</button></td>
                            <td><span class="badge">Complete</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div id="intern-detail-view" style="display: none;">
                <button class="back-btn" onclick="navigateToDashboard()" style="margin-bottom: 20px; padding: 8px 16px; background: #64748b; color: white; border: none; border-radius: 6px; cursor: pointer; font-weight: 600;">⬅ Trở lại danh sách</button>

                <div class="split-layout">

                    <div class="intern-profile-card">
                        <h4 id="target-intern-name">Milan Borjan</h4>
                        <div class="dept">Intern - Dev Department</div>

                        <div class="info-list">
                            <p><strong>Email:</strong> <span id="target-intern-email">milan@gmail.com</span></p>
                            <p><strong>Phone:</strong> <span id="target-intern-phone">0905 123 456</span></p>
                        </div>

                        <button class="btn-action" onclick="openActivityModal('create')" style="width: 100%; padding: 12px; background: var(--primary-color); color: white; border: none; border-radius: 8px; font-weight: 600; cursor: pointer;">✍ Ghi nhận hoạt động</button>
                    </div>

                    <div class="activity-container">
                        <h3>Lịch sử hoạt động của Intern</h3>

                        <div id="mentor-log-container" class="activity-container" style="gap: 20px; width: 100%;">
                            <p style="text-align:center; color:#64748b; padding: 20px;">Đang tải danh sách hoạt động từ hệ thống C#...</p>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </main>

    <div id="activity-modal" class="modal-overlay">
        <div class="modal-box">
            <div class="modal-header">
                <h4 id="modal-title">Ghi nhận hoạt động công việc</h4>
            </div>

            <form id="activity-form" onsubmit="handleFormSubmit(event)">
                <input type="hidden" id="form-activity-id" />

                <div class="form-group">
                    <label>Tên hoạt động</label>
                    <input type="text" id="form-name" required placeholder="Ví dụ: Review code, Fix Bug UI...">
                </div>

                <div class="form-group">
                    <label>Địa điểm</label>
                    <input type="text" id="form-location" required placeholder="Ví dụ: Phòng họp 2, Remote...">
                </div>

                <div class="form-group-row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div class="form-group">
                        <label>Ngày giờ thực hiện</label>
                        <input type="datetime-local" id="form-datetime" required>
                    </div>
                    <div class="form-group">
                        <label>Thời lượng (Bao lâu)</label>
                        <input type="text" id="form-duration" required placeholder="Ví dụ: 3 tiếng, 45 phút...">
                    </div>
                </div>

                <div class="form-group">
                    <label>Miêu tả chi tiết công việc</label>
                    <textarea id="form-desc" required placeholder="Mô tả tóm tắt nội dung Intern đã thực hiện..."></textarea>
                </div>

                <div class="form-group" style="border-top: 2px dashed #cbd5e1; padding-top: 15px; margin-top: 20px;">
                    <label style="color: var(--primary-color);">💬 Comment / Note phản hồi từ Intern (Chỉ xem):</label>
                    <textarea id="form-comment" disabled placeholder="Intern chưa để lại phản hồi cho hoạt động này..." style="background:#f1f5f9; font-style:italic;"></textarea>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-form cancel" onclick="closeActivityModal()">Cancel</button>
                    <button type="submit" id="btn-submit-form" class="btn-form submit">Submit</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const pairKey = "pair-01";
        let currentFormMode = 'create'; // Biến ghi nhớ trạng thái form

        function navigateToDashboard() {
            document.getElementById('intern-detail-view').style.display = 'none';
            document.getElementById('intern-list-view').style.display = 'block';
        }

        function openInternDetail(name, email, phone) {
            document.getElementById('intern-list-view').style.display = 'none';
            document.getElementById('intern-detail-view').style.display = 'block';
            document.getElementById('target-intern-name').innerText = name;
            document.getElementById('target-intern-email').innerText = email;
            document.getElementById('target-intern-phone').innerText = phone;

            loadMentorActivities();
        }

        // 1. Hàm GET nạp danh sách card
        function loadMentorActivities() {
            fetch(`/api/activities/getbykey?pairKey=${pairKey}`, {
                method: 'GET',
                headers: {
                    'Accept': 'application/json'
                }
            })
                .then(response => {
                    if (!response.ok) throw new Error("Không thể tải danh sách hoạt động từ API!");
                    return response.json();
                })
                .then(logs => {
                    const container = document.getElementById('mentor-log-container');
                    container.innerHTML = "";

                    if (logs.length === 0) {
                        container.innerHTML = `<div style="text-align:center; color:#64748b; padding: 25px; background:#f8fafc; border-radius:12px; border: 1px dashed #cbd5e1;">Chưa có hoạt động nhật ký nào được ghi nhận cho Intern này.</div>`;
                        return;
                    }

                    logs.forEach(log => {
                        const card = document.createElement('div');
                        card.className = "activity-card";

                        // Định dạng hiển thị chuỗi ngày tháng cho đẹp mắt trên giao diện card
                        let displayDate = log.Date ? log.Date.replace('T', ' ') : '';

                        card.innerHTML = `
                            <div class="activity-header">
                                <span class="activity-title">${log.Title}</span>
                                <span class="badge" style="background:#e2e8f0; color:#334155">Task #10${log.Id}</span>
                            </div>
                            <div class="activity-meta">
                                <div>📍 <strong>Địa điểm:</strong> ${log.Location}</div>
                                <div>⏱ <strong>Thời gian làm:</strong> ${log.Duration}</div>
                                <div>📅 <strong>Ngày giờ:</strong> ${displayDate}</div>
                            </div>
                            <p style="font-size:14px; color:#475569; margin-bottom:12px; line-height:1.5; padding: 0 5px;">
                                ${log.Description}
                            </p>
                            <div class="activity-comment">
                                <strong>Comment từ Intern:</strong> "${log.InternComment || "Intern chưa có phản hồi về hoạt động này."}"
                            </div>
                            <div class="card-actions">
                                <button class="btn-card view" onclick="viewSingleLogDetail(${log.Id}, '${log.Title.replace(/'/g, "\\'")}', '${log.Location.replace(/'/g, "\\'")}', '${log.Date}', '${log.Duration.replace(/'/g, "\\'")}', '${log.Description.replace(/'/g, "\\'")}', '${(log.InternComment || "").replace(/'/g, "\\'")}')">View</button>

                                <button class="btn-card edit" style="background: #ffc107; color: #334155;" onclick="openActivityModal('edit', ${log.Id}, '${log.Title.replace(/'/g, "\\'")}', '${log.Location.replace(/'/g, "\\'")}', '${log.Date}', '${log.Duration.replace(/'/g, "\\'")}', '${log.Description.replace(/'/g, "\\'")}', '${(log.InternComment || "").replace(/'/g, "\\'")}')">Edit</button>

                                <button class="btn-card" style="background: #ef4444; color: white;" onclick="deleteActivityByMentor(${log.Id})">Xóa</button>
                            </div>
                        `;
                        container.appendChild(card);
                    });
                })
                .catch(error => {
                    console.error("Lỗi tải API:", error);
                    document.getElementById('mentor-log-container').innerHTML = `<div style="color:#ef4444; text-align:center; padding:15px;">❌ Lỗi kết nối dữ liệu Server C#!</div>`;
                });
        }

        // Hàm đổ dữ liệu lên Modal xem chi tiết (Read-only) khi bấm View
        function viewSingleLogDetail(id, title, location, date, duration, desc, comment) {
            const modal = document.getElementById('activity-modal');
            document.getElementById('modal-title').innerText = "🔍 Chi tiết hoạt động";
            document.getElementById('btn-submit-form').style.display = "none";

            document.getElementById('form-name').value = title;
            document.getElementById('form-location').value = location;
            document.getElementById('form-datetime').value = date;
            document.getElementById('form-duration').value = duration;
            document.getElementById('form-desc').value = desc;
            document.getElementById('form-comment').value = comment || "Intern chưa để lại phản hồi.";

            enableFormInputs(false);
            modal.classList.add('open');
        }

        // Hàm mở Modal thông minh (Phân biệt chế độ Create / Edit)
        function openActivityModal(mode, id = null, title = '', location = '', date = '', duration = '', desc = '', comment = '') {
            const modal = document.getElementById('activity-modal');
            const titleHeader = document.getElementById('modal-title');
            const submitBtn = document.getElementById('btn-submit-form');

            currentFormMode = mode;
            enableFormInputs(true);
            document.getElementById('form-comment').disabled = true;

            if (mode === 'create') {
                titleHeader.innerText = "✍ Ghi nhận hoạt động mới";
                submitBtn.style.display = "block";
                submitBtn.innerText = "Submit";
                document.getElementById('activity-form').reset();
                document.getElementById('form-activity-id').value = "";
            }
            else if (mode === 'edit') {
                titleHeader.innerText = "✏ Chỉnh sửa thông tin hoạt động";
                submitBtn.style.display = "block";
                submitBtn.innerText = "Save Changes";

                document.getElementById('form-activity-id').value = id;
                document.getElementById('form-name').value = title;
                document.getElementById('form-location').value = location;
                document.getElementById('form-datetime').value = date;
                document.getElementById('form-duration').value = duration;
                document.getElementById('form-desc').value = desc;
                document.getElementById('form-comment').value = comment || "Intern chưa để lại phản hồi.";
            }

            modal.classList.add('open');
        }

        // ĐÃ BỔ SUNG: Hàm đóng modal điều khiển tắt class overlay
        function closeActivityModal() {
            document.getElementById('activity-modal').classList.remove('open');
        }

        function enableFormInputs(status) {
            const inputs = ['form-name', 'form-location', 'form-datetime', 'form-duration', 'form-desc'];
            inputs.forEach(id => {
                document.getElementById(id).disabled = !status;
            });
        }

        function handleFormSubmit(event) {
            event.preventDefault();

            const id = document.getElementById('form-activity-id').value;
            const activityData = {
                PairKey: pairKey,
                Title: document.getElementById('form-name').value,
                Location: document.getElementById('form-location').value,
                Date: document.getElementById('form-datetime').value,
                Duration: document.getElementById('form-duration').value,
                Description: document.getElementById('form-desc').value,
                InternComment: ""
            };

            let apiUrl = '/api/activities/create';
            // 👇 LUÔN LUÔN ĐỂ POST ĐỂ NÉ BỘ LỌC CHẶN CỦA SERVER 👇
            let httpMethod = 'POST';

            if (currentFormMode === 'edit') {
                // Đổi đường dẫn sang một router POST riêng cho việc Update
                apiUrl = `/api/activities/update/${id}`;
            }

            fetch(apiUrl, {
                method: httpMethod,
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(activityData)
            })
                .then(response => {
                    if (!response.ok) throw new Error("Gặp sự cố xử lý dữ liệu!");
                    return response.json();
                })
                .then(result => {
                    if (result.success) {
                        alert(result.message);
                        closeActivityModal();
                        loadMentorActivities();
                    }
                })
                .catch(error => {
                    console.error("Lỗi thực thi form:", error);
                    alert("Không thể hoàn tất thao tác biểu mẫu!");
                });
        }
        // 3. Hàm DELETE xóa nhật ký
        function deleteActivityByMentor(id) {
            if (!confirm("Bạn có chắc chắn muốn xóa vĩnh viễn hoạt động này không? Dữ liệu bên màn hình của Intern cũng sẽ mất theo.")) {
                return;
            }

            fetch(`/api/activities/delete/${id}`, {
                method: 'DELETE',
                headers: {
                    'Accept': 'application/json'
                }
            })
                .then(response => {
                    if (!response.ok) throw new Error("Server từ chối thực hiện lệnh xóa!");
                    return response.json();
                })
                .then(result => {
                    if (result.success) {
                        alert(result.message);
                        loadMentorActivities();
                    }
                })
                .catch(error => {
                    console.error("Lỗi DELETE API:", error);
                    alert("Không thể xóa hoạt động. Vui lòng rà soát lại kết nối!");
                });
        }
    </script>
</body>
</html>