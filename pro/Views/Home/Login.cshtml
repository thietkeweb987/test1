
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Management System</title>

    <link rel="stylesheet" href="/GiaoDien/login.css">
</head>
<body>

    <div class="login-card">
        <div class="login-header">
            <span class="logo-icon">🔑</span>
            <h2>Đăng Nhập Hệ Thống</h2>
            <p>Vui lòng chọn đúng vai trò và nhập tài khoản</p>
        </div>

        <form method="post" action="/Home/Login">

            <div class="form-group">
                <label for="role">Vai trò của bạn</label>
                <select id="role" name="Role" required>
                    <option value="" disabled selected>-- Chọn vai trò quản lý --</option>
                    <option value="admin">Quản trị viên (Admin)</option>
                    <option value="mentor">Nhân viên hướng dẫn (Mentor)</option>
                    <option value="intern">Thực tập sinh (Intern)</option>
                </select>
                @Html.ValidationMessage("Role", new { @style = "color: #ef4444; font-size: 13px; margin-top: 5px; display: block; font-weight: 600;" })
            </div>

            <div class="form-group">
                <label for="email">Email công ty</label>
                <input type="email" id="email" name="Email" required placeholder="name@company.com" value="@(Model != null ? Model.Email : "")">

                @Html.ValidationMessage("Email", new { @style = "color: #ef4444; font-size: 13px; margin-top: 5px; display: block; font-weight: 600;" })
            </div>

            <div class="form-group">
                <label for="password">Mật khẩu</label>
                <input type="password" id="password" name="Password" required placeholder="••••••••">

                @Html.ValidationMessage("Password", new { @style = "color: #ef4444; font-size: 13px; margin-top: 5px; display: block; font-weight: 600;" })
            </div>

            <button type="submit" class="btn-login-submit">Đăng nhập</button>
        </form>

    </div>

</body>
</html>