
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Management System</title>
    <link rel="stylesheet" href="~/GiaoDien/login.css">
</head>
<body>

    <div class="login-card">
        <div class="login-header">
            <span class="logo-icon">🔑</span>
            <h2>Đăng Nhập Hệ Thống</h2>
            <p>Vui lòng chọn đúng vai trò và nhập tài khoản</p>
        </div>

        <form onsubmit="executeLogin(event)">

            <div class="form-group">
                <label for="role">Vai trò của bạn</label>
                <select id="role" required>
                    <option value="" disabled selected>-- Chọn vai trò quản lý --</option>
                    <option value="admin">Quản trị viên (Admin)</option>
                    <option value="mentor">Nhân viên hướng dẫn (Mentor)</option>
                    <option value="intern">Thực tập sinh (Intern)</option>
                </select>
            </div>

            <div class="form-group">
                <label for="email">Email công ty</label>
                <input type="email" id="email" required placeholder="name@company.com" autocomplete="email">
            </div>

            <div class="form-group">
                <label for="password">Mật khẩu</label>
                <input type="password" id="password" required placeholder="••••••••" autocomplete="current-password">
            </div>

            <button type="submit" class="btn-login-submit">Đăng nhập</button>
        </form>

        <div class="login-footer">
            <a href="index.html">← Quay lại trang chủ</a>
        </div>
    </div>

    <script>
        function executeLogin(event) {
            event.preventDefault(); // Chặn tải lại trang

            const role = document.getElementById('role').value;
            const email = document.getElementById('email').value;

            alert(`Đăng nhập thành công với vai trò: ${role.toUpperCase()}`);

            // Chuyển hướng thông minh dựa trên Option Role người dùng chọn
            if (role === 'admin') {
                window.location.href = "/Home/Page1"; // Đã sửa: Gọi hàm Page1 trong HomeController
            } else if (role === 'mentor') {
                window.location.href = "/Home/Page2"; // Đã sửa: Gọi hàm Page2 trong HomeController
            } else if (role === 'intern') {
                window.location.href = "/Home/Page3"; // Đã sửa: Gọi hàm Page3 trong HomeController
            }
        }
    </script>

</body>
</html>